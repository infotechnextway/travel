{
  "name": "api",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "node node_modules/typescript/bin/tsc --noEmitOnError false",
    "start": "node dist/server.js",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:integration": "jest --config jest.integration.config.js",
    "test:e2e": "jest --config jest.e2e.config.js",
    "seed": "tsx src/seeds/seed.ts",
    "migrate": "tsx src/seeds/migrate.ts"
  },
  "dependencies": {
    "@india-travel/shared-types": "*",
    "aws-sdk": "^2.1500.0",
    "axios": "^1.6.0",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "date-fns": "^3.0.0",
    "dotenv": "^16.4.0",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.0",
    "firebase-admin": "^12.0.0",
    "helmet": "^7.1.0",
    "joi": "^17.12.0",
    "jsonwebtoken": "^9.0.2",
    "lodash": "^4.17.21",
    "mongoose": "^8.0.0",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.0",
    "passport": "^0.7.0",
    "passport-apple": "^2.0.0",
    "passport-google-oauth20": "^2.0.0",
    "qrcode": "^1.5.3",
    "razorpay": "^2.9.0",
    "sharp": "^0.33.0",
    "slugify": "^1.6.6",
    "speakeasy": "^2.0.0",
    "stripe": "^14.0.0",
    "twilio": "^5.0.0",
    "uuid": "^9.0.0",
    "winston": "^3.11.0"
