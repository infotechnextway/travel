# Application
NODE_ENV=development
PORT=4000
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_APP_URL=http://localhost:3000
ADMIN_URL=http://localhost:3001
VENDOR_URL=http://localhost:3002

# Database
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/india-travel?retryWrites=true&w=majority
MONGODB_DB_NAME=india-travel

# Authentication
JWT_SECRET=your-jwt-secret-min-32-characters-long
JWT_REFRESH_SECRET=your-refresh-secret-min-32-characters-long
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d
OTP_EXPIRATION=10
OTP_SECRET=your-otp-secret

# Social Auth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=

# Payments
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=

# AWS
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
AWS_S3_BUCKET=india-travel-assets
AWS_S3_DOCUMENTS_BUCKET=india-travel-documents
AWS_CLOUDFRONT_DOMAIN=

# Firebase
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=
FIREBASE_DATABASE_URL=
FIREBASE_STORAGE_BUCKET=

# Google Maps
GOOGLE_MAPS_API_KEY=

# Email
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@indiatravel.market

# WhatsApp Business API
WHATSAPP_API_KEY=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=

# Encryption
ENCRYPTION_KEY=your-32-char-encryption-key

# Flutter
FLUTTER_API_BASE_URL=http://localhost:4000/v1
